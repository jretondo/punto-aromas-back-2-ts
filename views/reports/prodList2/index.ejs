<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Etiquetas de góndola</title>
</head>
<body>
    <%- style %>

    <% const labelsPerPage = pageConfig.columns * pageConfig.rows; %>

    <% pages.forEach((pageItems, pageIndex) => { %>
        <section
            class="page<%= pageIndex < pages.length - 1 ? ' page-break' : '' %>"
            style="
                --margin-mm: <%= pageConfig.marginMm %>;
                --gap-mm: <%= pageConfig.gapMm %>;
                --columns: <%= pageConfig.columns %>;
                --rows: <%= pageConfig.rows %>;
            "
        >
            <div class="labels-grid">
                <% for (let i = 0; i < labelsPerPage; i++) { %>
                    <% const item = pageItems[i]; %>
                    <% if (!item) { %>
                        <div class="label label-empty"></div>
                    <% } else { %>
                        <article class="label">
                            <header class="label-header">
                                <div class="label-name"><%- item.name %></div>
                                <% if (item.description) { %>
                                    <div class="label-description">(<%- item.description %>)</div>
                                <% } %>
                            </header>

                            <div class="label-price"><%- item.price %></div>

                            <% if (item.tiers.length > 0) { %>
                                <div class="label-divider"></div>
                                <div class="label-tiers">
                                    <% item.tiers.forEach((tier) => { %>
                                        <div class="label-tier-row">
                                            <span class="label-tier-label"><%- tier.label %>:</span>
                                            <span class="label-tier-price"><%- tier.price %></span>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </article>
                    <% } %>
                <% } %>
            </div>

            <footer class="page-footer">PÁGINA <%= pageIndex + 1 %> DE <%= pages.length %></footer>
        </section>
    <% }) %>
</body>
</html>
